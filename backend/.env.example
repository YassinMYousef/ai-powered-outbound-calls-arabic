# Data stores
DATABASE_URL=postgresql+psycopg://callcenter:callcenter@localhost:5432/callcenter
REDIS_URL=redis://localhost:6379/0

# Structured logging (Promtail reads this JSONL file)
LOG_LEVEL=INFO
LOG_FILE=logs/callcenter.jsonl
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Speech / LLM providers
OPENAI_API_KEY=
STT_MODEL=whisper-1
STT_PROMPT_AR=
TTS_PROVIDER=elevenlabs
TTS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_VOICE_ID=L10lEremDiJfPicq5CPh
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TEXT_NORMALIZATION=auto
ELEVENLABS_PRONUNCIATION_DICTIONARY_ID=
ELEVENLABS_PRONUNCIATION_DICTIONARY_VERSION_ID=
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.0
ELEVENLABS_USE_SPEAKER_BOOST=true

# RAG / embeddings
TEI_URL=http://localhost:8080
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSIONS=1024
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
ANTHROPIC_API_KEY=
ANSWER_MODEL=claude-sonnet-5
ANSWER_MAX_TOKENS=1024
ANSWER_EFFORT=medium

# Telephony
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=http://localhost:8000

# Reserved for the future auth sprint
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
