# Data stores
DATABASE_URL=postgresql+psycopg://callcenter:callcenter@localhost:5432/callcenter
REDIS_URL=redis://localhost:6379/0

# Structured logging (Promtail reads this JSONL file)
LOG_LEVEL=INFO
LOG_FILE=logs/callcenter.jsonl
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Speech / LLM providers
OPENAI_API_KEY=
TTS_PROVIDER=
TTS_API_KEY=

# RAG / vector DB
PINECONE_API_KEY=
PINECONE_INDEX=callcenter-kb

# Telephony
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=http://localhost:8000

# Reserved for the future auth sprint
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
